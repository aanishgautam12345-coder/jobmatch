# -- Database --
DATABASE_URL=postgresql://postgres:dev@localhost:5432/jobmatch

# -- Adzuna API --
ADZUNA_APP_ID=your_app_id_here
ADZUNA_APP_KEY=your_app_key_here

# -- Reed.co.uk API --
REED_API_KEY=your_reed_api_key_here

# -- OpenAI --
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5.6-sol

# -- JWT Auth --
SECRET_KEY=change-this-to-a-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
APP_BASE_URL=http://localhost:5000
PASSWORD_RESET_EXPIRY_MINUTES=15

# -- Email (Gmail SMTP - free) --
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
EMAIL_FROM=your_email@gmail.com
SMTP_TIMEOUT_SECONDS=10

# -- Dedicated notification scheduler (`python -m scripts.run_scheduler`) --
SCHEDULER_ENABLED=false
SCHEDULER_TIMEZONE=UTC
SCHEDULER_INSTANT_INTERVAL_MINUTES=15
SCHEDULER_DAILY_TIME=09:00
SCHEDULER_WEEKLY_DAY=mon
SCHEDULER_WEEKLY_TIME=09:00
NOTIFICATION_MAX_RETRIES=3
NOTIFICATION_DIGEST_LIMIT=5
RECOMMENDED_SEARCH_THRESHOLD=0.35
